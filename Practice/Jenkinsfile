pipeline {
    agent any

    environment {
        JUNIT_JAR_URL = 'https://repo1.maven.org/maven2/org/junit/platform/junit-platform-console-standalone/1.7.1/junit-platform-console-standalone-1.7.1.jar'
        JUNIT_JAR_PATH = 'lib/junit.jar'
        CLASS_DIR = 'classes'
        REPORT_DIR = 'test-reports'

        // Email settings
        MAIL_TO = 'cube1793@g.hongik.ac.kr'
        MAIL_FROM = 'jenkins-demo@local.test'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Prepare') {
            steps {
                sh '''
                    mkdir -p ${CLASS_DIR}
                    mkdir -p ${REPORT_DIR}
                    mkdir -p lib
                    echo "[+] Downloading JUnit JAR..."
                    curl -L -o ${JUNIT_JAR_PATH} ${JUNIT_JAR_URL}
                '''
            }
        }

        stage('Build') {
            steps {
                sh '''
                    echo "[+] Compiling source files..."
                    cd Practice
                    find src -name "*.java" > sources.txt
                    javac -encoding UTF-8 -d ../${CLASS_DIR} -cp ../${JUNIT_JAR_PATH} @sources.txt
                '''
            }
        }

        stage('Test') {
            steps {
                sh '''
                    echo "[+] Running tests with JUnit..."
                    java -jar ${JUNIT_JAR_PATH} \
                         --class-path ${CLASS_DIR} \
                         --scan-class-path \
                         --details=tree \
                         --details-theme=ascii \
                         --reports-dir ${REPORT_DIR} \
                         --config=junit.platform.output.capture.stdout=true \
                         --config=junit.platform.reporting.open.xml.enabled=true \
                         > ${REPORT_DIR}/test-output.txt
                '''
            }
        }
    }

    post {	
        always {
            echo "[*] Archiving test results..."
            junit "${REPORT_DIR}/**/*.xml"
            archiveArtifacts artifacts: "${REPORT_DIR}/**/*", allowEmptyArchive: true
        }

        failure {
            echo "Build or test failed!"

            script {
                try {
                    emailext(
                        to: "${env.MAIL_TO}",
                        from: "${env.MAIL_FROM}",
                        replyTo: "${env.MAIL_FROM}",
                        subject: "[Jenkins] FAILURE: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                        body: """
Jenkins 빌드 또는 테스트가 실패했습니다.

Job Name: ${env.JOB_NAME}
Build Number: ${env.BUILD_NUMBER}
Build Result: ${currentBuild.currentResult}
Build URL: ${env.BUILD_URL}

Console Output을 확인하여 실패 원인을 분석하세요.
""",
                        mimeType: 'text/plain',
                        attachLog: true
                    )

                    echo "Failure notification email sent to ${env.MAIL_TO}"
                } catch (err) {
                    echo "Email sending failed: ${err}"
                }
            }
        }

        success {
            echo "Build and test succeeded!"

            script {
                try {
                    emailext(
                        to: "${env.MAIL_TO}",
                        from: "${env.MAIL_FROM}",
                        replyTo: "${env.MAIL_FROM}",
                        subject: "[Jenkins] SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                        body: """
Jenkins 빌드와 테스트가 성공했습니다.

Job Name: ${env.JOB_NAME}
Build Number: ${env.BUILD_NUMBER}
Build Result: ${currentBuild.currentResult}
Build URL: ${env.BUILD_URL}

JUnit 테스트 결과와 test-output.txt 파일이 Jenkins Artifact로 저장되었습니다.
""",
                        mimeType: 'text/plain',
                        attachmentsPattern: "${env.REPORT_DIR}/test-output.txt"
                    )

                    echo "Success notification email sent to ${env.MAIL_TO}"
                } catch (err) {
                    echo "Email sending failed: ${err}"
                }
            }
        }
    }
}